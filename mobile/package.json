{
  "name": "bookmarkfold-mobile",
  "version": "1.0.0",
  "main": "index.ts",
  "dependencies": {
    "@expo-google-fonts/instrument-serif": "^0.4.1",
    "@expo-google-fonts/space-grotesk": "^0.4.1",
    "expo": "~56.0.8",
    "expo-font": "~56.0.5",
    "expo-image": "~56.0.9",
    "expo-linear-gradient": "~56.0.4",
    "expo-linking": "~56.0.13",
    "expo-secure-store": "~56.0.4",
    "expo-status-bar": "~56.0.4",
    "expo-system-ui": "~56.0.5",
    "expo-web-browser": "~56.0.5",
    "react": "19.2.3",
    "react-native": "0.85.3",
    "react-native-safe-area-context": "~5.7.0"
  },
  "devDependencies": {
    "@types/react": "~19.2.2",
    "typescript": "~6.0.3"
  },
  "scripts": {
    "start": "expo start --dev-client",
    "android": "expo run:android",
    "android:prebuild": "expo prebuild --platform android",
    "android:build": "bash scripts/android-build.sh",
    "android:install": "adb install -r android/app/build/outputs/apk/debug/app-debug.apk",
    "android:reinstall": "bash scripts/android-reinstall.sh",
    "android:go": "expo start --android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "typecheck": "tsc --noEmit"
  },
  "private": true
}
